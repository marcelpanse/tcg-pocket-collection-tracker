{
  "name": "tcg-pocket-collection-tracker",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "lint": "pnpm run biome:check",
    "lint:fix": "pnpm run biome:fix",
    "biome:check": "pnpm biome check --error-on-warnings --formatter-enabled=true --linter-enabled=true .",
    "biome:fix": "pnpm biome check --write --error-on-warnings --formatter-enabled=true --linter-enabled=true .",
    "prepare": "lefthook install",
    "dev": "pnpm --filter frontend run dev",
    "build": "pnpm --filter frontend run build",
    "scraper": "tsx scripts/scraper.js && node scripts/download-packs.js && tsx scripts/generate-scan-hashes.ts && node scripts/scrape-missions.js && pnpm lint:fix",
    "hashes": "tsx scripts/generate-scan-hashes.ts",
    "sync-locales": "node scripts/sync-locales.js"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "lefthook": "^2.1.9",
    "tsx": "^4.22.4"
  },
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "fs-extra": "^11.3.5",
    "glob": "^13.0.0",
    "node-fetch": "^3.3.2",
    "sharp": "0.35.2"
  }
}
